local success, Games = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/RedScripter102/Remastered-Script/refs/heads/main/Gamelist"))()
end)

if not success or type(Games) ~= "table" then
    game:GetService("Players").LocalPlayer:Kick("Failed to load game list, try rejoin \n(if this show again then executor dont support)")
    return
end

local FoundGameSupported = false

for PlaceID, Execute in pairs(Games) do
    if PlaceID == game.PlaceId then
        FoundGameSupported = true
        pcall(function()
            loadstring(game:HttpGet(Execute))()
        end)
        break
    end
end

if not FoundGameSupported then
game:GetService("StarterGui"):SetCore("SendNotification",{
	Title = "Exploit System",
	Text = "[?] Game Not Supported.",
	Icon = "rbxassetid://7734053426"
})
end
